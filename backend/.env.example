DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEON_AUTH_URL=https://your-endpoint.neonauth.region.aws.neon.tech/yourdb/auth

# Gmail SMTP for email alerts — use an App Password, not your real password
# (Google Account -> Security -> App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com

# Local AI triage assistant (optional — defaults below match `ollama serve`)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Shared secret required in the X-API-Key header on POST /events/ingest.
# Generate your own: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=change-me-to-a-random-value
